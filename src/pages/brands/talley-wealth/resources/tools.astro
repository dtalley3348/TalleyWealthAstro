---
import TalleyPage from '../../../../components/talley-wealth/TalleyPage.astro';

const tools = [
  {
    eyebrow: 'Calculator',
    title: 'Retirement Readiness Calculator',
    body: 'Estimate whether your current path may support the income you want, then stress-test the result with a sequence-risk simulator.',
    href: '/calculators',
    label: 'Open calculator',
  },
  {
    eyebrow: 'Interactive explainer',
    title: 'S-Corp Tax Savings Visual',
    body: 'See where S-Corp payroll-tax savings can appear, why reasonable compensation matters, and why Tennessee can change the answer.',
    href: '/learn/s-corp-tax-savings-explained',
    label: 'Open visual',
  },
  {
    eyebrow: 'Article',
    title: 'Should I Elect S-Corp Status?',
    body: 'Read the plain-English companion piece on owner pay, Tennessee nuance, fit, cash flow, and why the decision is rarely automatic.',
    href: '/resources/blog/should-i-elect-s-corp-status',
    label: 'Read article',
  },
];

const relatedLinks = [
  {
    title: 'Business owner tax planning',
    body: 'See how entity, owner pay, tax, and household decisions fit together for local owners.',
    href: '/business-owner-tax-planning-tri-cities-tn',
  },
  {
    title: 'Retirement guide',
    body: 'A fuller framework for the retirement questions the calculators are meant to surface.',
    href: '/guide',
  },
  {
    title: 'Learning Center',
    body: 'Short answer-first explainers for retirement, tax, investing, and planning questions.',
    href: '/resources/learning-center',
  },
];
---

<TalleyPage title="Planning Tools | Talley Wealth" description="Interactive calculators, visual explainers, and planning tools from Talley Wealth.">
  <section class="bg-muted/35">
    <div class="section-container py-20">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Planning Tools</p>
      <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">Tools for seeing the planning question more clearly.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        Some are calculators. Some are visual explainers. All of them are educational starting points built to surface better questions. A coordinated plan still has to connect those answers.
      </p>
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container py-20">
      <div class="grid gap-5 md:grid-cols-3">
        {tools.map((tool) => (
          <a href={tool.href} class="rounded-lg border border-border bg-card p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{tool.eyebrow}</p>
            <h2 class="mt-3 font-serif text-2xl font-bold text-primary">{tool.title}</h2>
            <p class="mt-4 leading-relaxed text-muted-foreground">{tool.body}</p>
            <span class="mt-6 inline-flex font-bold text-accent">{tool.label} <span aria-hidden="true">-&gt;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-20">
    <div class="section-container">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Where to go next</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">Use the tool, then bring the question into context.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {relatedLinks.map((item) => (
          <a href={item.href} class="group rounded-lg border border-border bg-background p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <h3 class="font-serif text-xl font-bold text-primary transition group-hover:text-accent">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-accent">Learn more <span aria-hidden="true">&nbsp;-&gt;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</TalleyPage>
