---
import type { BasicPage } from '../../data/talley-wealth/site-content';
import CalendlyEmbed from './CalendlyEmbed.astro';

interface Props {
  page: BasicPage;
  formSource?: string;
  formTitle?: string;
}

const { page, formSource, formTitle } = Astro.props;
---

<section class="bg-muted/40">
  <div class="section-container grid min-h-[560px] items-center gap-12 py-20 lg:grid-cols-[1fr_0.85fr]">
    <div data-reveal="left">
      {page.eyebrow && (
        <p class="mb-5 flex items-center gap-4 text-sm font-bold uppercase tracking-[0.18em] text-accent">
          <span class="h-1 w-16 rounded-full bg-accent"></span>
          {page.eyebrow}
        </p>
      )}
      <h1 class="max-w-4xl font-serif text-4xl font-bold leading-[1.08] text-primary md:text-5xl">{page.heading}</h1>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-muted-foreground">{page.intro}</p>
      {page.cta && (
        <a href="/get-started" class="mt-8 inline-flex rounded-md bg-accent px-5 py-3 font-semibold text-accent-foreground transition hover:brightness-95">{page.cta}</a>
      )}
    </div>
    {page.image && (
      <div data-reveal="right" class="overflow-hidden rounded-xl border-[14px] border-primary/15 shadow-elegant-lg">
        <img decoding="async" src={page.image} alt="" class="aspect-[4/3] w-full object-cover" loading="eager" />
      </div>
    )}
  </div>
</section>

{page.sections && (
  <section class="bg-background">
    <div class="section-container py-20">
      <div class="grid gap-5 md:grid-cols-3">
        {page.sections.map((item) => (
          <article class="rounded-lg border border-border bg-card p-6 shadow-elegant" data-reveal>
            <h2 class="font-serif text-2xl font-bold text-primary">{item.title}</h2>
            <p class="mt-4 leading-relaxed text-muted-foreground">{item.body}</p>
            {item.href && <a href={item.href} class="mt-5 inline-flex font-bold text-accent">{item.href.startsWith('/') ? 'Read more' : item.href}</a>}
          </article>
        ))}
      </div>
    </div>
  </section>
)}

{formSource && (
  <section class="bg-muted/30">
    <div class="section-container grid gap-10 py-20 lg:grid-cols-[0.8fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Next step</p>
        <h2 class="mt-4 font-serif text-3xl font-bold text-primary md:text-4xl">If this sounds familiar, start with a short conversation.</h2>
      </div>
      <CalendlyEmbed source={formSource} title={formTitle ?? 'Schedule an Explore Call'} description="Pick a time for a short conversation with David." />
    </div>
  </section>
)}
