---
import TalleyPage from '../../../components/talley-wealth/TalleyPage.astro';
import CtaSection from '../../../components/talley-wealth/CtaSection.astro';
import TestimonialsSection from '../../../components/talley-wealth/TestimonialsSection.astro';

const primaryPaths = [
  {
    quote: "\"You are close enough to retirement that taxes, income, investments, Medicare, Social Security, and estate decisions all start to matter at the same time.\"",
    detail: 'Near retirement',
    body: 'You are close enough to retirement that taxes, income, investments, Medicare, Social Security, and estate decisions all start to matter at the same time.',
    href: '/financial-advisor-for-pre-retirees',
  },
  {
    quote: "\"You have profit, tax questions, cash-flow decisions, and personal wealth goals, but no one clearly helping you think through all of it.\"",
    detail: 'Business owners',
    body: 'You have profit, tax questions, cash-flow decisions, and personal wealth goals, but no one clearly helping you think through all of it.',
    href: '/financial-advisor-for-business-owners',
  },
];

const secondaryFits = [
  {
    quote: "\"My compensation is getting more complicated, and I do not have time to figure out every tax and timing decision myself.\"",
    detail: 'Executives and equity comp',
    href: '/financial-advisor-for-executives-equity-comp',
  },
  {
    quote: "\"I inherited money, and I do not want to make a mistake just because I don't know what to ask.\"",
    detail: 'Inherited wealth',
    href: '/financial-advisor-for-inherited-wealth',
  },
  {
    quote: "\"I make good money, but I want someone capable to help keep the important pieces moving.\"",
    detail: 'Busy high earners',
    href: '/financial-advisor-for-healthcare-professionals',
  },
];

const trustStats = ['CFP®, ChFC®, EA', '67 five-star Google reviews'];
---

<TalleyPage
  title="Talley Wealth | Financial Planning, Tax & Investing"
  description="Financial planning in Johnson City for retirement income, tax strategy, investments, and major financial transitions."
  heroTransparent
  ogImage="/brands/talley-wealth/hero-bg.webp"
>
  <section class="relative flex min-h-[85vh] items-center overflow-hidden bg-primary pt-20 text-primary-foreground sm:pt-28">
    <img decoding="async" src="/brands/talley-wealth/hero-bg.webp" alt="" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary from-40% via-primary/90 via-70% to-primary/60"></div>

    <div class="section-container relative z-10 w-full min-w-0">
      <div class="tw-home-hero__copy max-w-2xl min-w-0">
        <div class="mb-6 flex items-center gap-3">
          <div class="h-1 w-16 rounded-full bg-accent"></div>
          <span class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Johnson City, Tennessee</span>
        </div>
        <h1 class="font-serif text-4xl font-bold leading-tight text-primary-foreground md:text-5xl">
          Financial planning built for retirement, tax, and business decisions.
        </h1>
        <p class="mt-5 max-w-full text-lg leading-relaxed text-primary-foreground/80">
          Talley Wealth helps retirees, business owners, and high-income households make clearer decisions across retirement, taxes, investments, and long-term strategy.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {primaryPaths.map((item) => (
            <a href={item.href} class="group rounded-lg border border-primary-foreground/25 bg-primary-foreground/10 p-4 text-left transition hover:-translate-y-0.5 hover:bg-primary-foreground/15">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-accent">{item.detail}</p>
              <p class="mt-2 font-serif text-base font-bold italic leading-snug text-primary-foreground">{item.quote}</p>
              <span class="mt-3 inline-flex text-xs font-bold text-primary-foreground/75 transition group-hover:text-accent">Start here <span aria-hidden="true">&nbsp;-&gt;</span></span>
            </a>
          ))}
        </div>
        <div class="mt-8 flex min-w-0 flex-col gap-4 sm:flex-row">
          <a href="/get-started" class="inline-flex max-w-full justify-center rounded-md bg-accent px-6 py-4 text-center font-bold text-accent-foreground transition hover:bg-accent/90">Schedule an Explore Call</a>
          <a href="/how-we-work/what-to-expect" class="inline-flex max-w-full justify-center rounded-md border border-primary-foreground/40 bg-primary-foreground/10 px-6 py-4 text-center font-bold text-primary-foreground transition hover:bg-primary-foreground/20">How We Work</a>
        </div>
        <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-primary-foreground/75">
          {trustStats.map((stat) => (
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              <span>{stat}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border/50 bg-card">
    <div class="section-container py-8">
      <div class="grid gap-5 text-sm text-muted-foreground md:grid-cols-4">
        <p><strong class="block font-serif text-lg text-primary">Retirement decisions</strong> Income, taxes, investments, Medicare, Social Security, and estate choices modeled together.</p>
        <p><strong class="block font-serif text-lg text-primary">Business-owner strategy</strong> Tax, cash flow, owner pay, entity, retirement plan, and personal wealth decisions in one conversation.</p>
        <p><strong class="block font-serif text-lg text-primary">Plan first</strong> The advice starts with your life, not a product or portfolio model.</p>
        <p><strong class="block font-serif text-lg text-primary">Founder-led</strong> You work directly with David, supported by a prepared team.</p>
      </div>
    </div>
  </section>

  <section class="bg-card py-24">
    <div class="section-container">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="relative">
          <div class="aspect-[3/2] overflow-hidden rounded-lg shadow-elegant-xl">
            <img decoding="async" src="/brands/talley-wealth/david-stephenee-window.jpg" alt="David Talley and Stephenee Carberry at Talley Wealth" class="h-full w-full object-cover"  loading="lazy" />
          </div>
        </div>

        <div>
          <div class="mb-6 flex items-center gap-3">
            <div class="gold-line"></div>
            <span class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Why It Matters</span>
          </div>
          <h2 class="font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">
            Most people reach this point with pieces, not a real plan.
          </h2>
          <div class="mt-6 space-y-5 text-lg leading-relaxed text-muted-foreground">
            <p>They have investment accounts. A CPA. Maybe an old retirement projection. Estate documents from years ago. A few good decisions made at different times by different people.</p>
            <blockquote class="border-l-4 border-accent py-2 pl-5">
              <p class="font-serif text-2xl italic leading-snug text-primary">The problem is not usually a lack of effort. It is that the moving parts are being handled in separate silos.</p>
            </blockquote>
            <p>That matters most in the two lanes where our work usually has the most leverage: when retirement is close and when a business owner needs tax-aware strategy that connects the business to the family's personal wealth. Other situations can still fit, but those are the core patterns.</p>
            <p>Our work runs the other way around. We build the plan first, then let the plan guide the investment allocation, tax strategy, estate coordination, and ongoing decisions.</p>
          </div>
          <a href="/pricing" class="mt-8 inline-flex items-center gap-2 font-bold text-accent transition hover:gap-3">
            How we get paid and how the engagement is structured <span aria-hidden="true">-&gt;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-24">
    <div class="section-container">
      <div class="mx-auto mb-16 max-w-3xl text-center">
        <div class="mb-6 flex items-center justify-center gap-3">
          <div class="h-1 w-16 rounded-full bg-accent"></div>
          <span class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Sound Familiar?</span>
          <div class="h-1 w-16 rounded-full bg-accent"></div>
        </div>
        <h2 class="font-serif text-3xl font-bold text-primary md:text-4xl">Most people reach out through one of two doors.</h2>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
          The details are different, but the feeling is familiar: there is enough going on now that a more thoughtful plan would feel useful.
        </p>
      </div>

      <div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-2">
        {primaryPaths.map((item) => (
          <a href={item.href} class="group h-full rounded-lg border border-border/30 bg-card p-7 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-accent">{item.detail}</p>
            <p class="mt-4 font-serif text-lg font-bold italic text-primary">{item.quote}</p>
            <p class="mt-4 leading-relaxed text-muted-foreground">{item.body}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-accent">Learn more <span aria-hidden="true">&nbsp;-&gt;</span></span>
          </a>
        ))}
      </div>

      <div class="mx-auto mt-10 max-w-5xl rounded-lg border border-border/40 bg-card/70 p-6">
        <p class="text-center text-sm font-bold uppercase tracking-[0.16em] text-accent">Also a fit when the complexity justifies the work</p>
        <div class="mt-5 grid gap-4 md:grid-cols-3">
          {secondaryFits.map((item) => (
            <a href={item.href} class="group rounded-md border border-border/40 bg-background p-4 transition hover:border-accent/50">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-muted-foreground">{item.detail}</p>
              <p class="mt-2 text-sm italic leading-relaxed text-primary">{item.quote}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="/who-we-help" class="inline-flex rounded-md bg-accent px-6 py-3 font-bold text-accent-foreground transition hover:bg-accent/90">See who this tends to fit</a>
      </div>
    </div>
  </section>

  <section class="bg-primary py-24 text-primary-foreground">
    <div class="section-container">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mb-6 flex items-center justify-center gap-3">
          <div class="h-1 w-16 rounded-full bg-accent"></div>
          <span class="text-sm font-bold uppercase tracking-[0.18em] text-accent">The Keystone Method™</span>
          <div class="h-1 w-16 rounded-full bg-accent"></div>
        </div>
        <h2 class="font-serif text-3xl font-bold md:text-4xl">Keystone turns the questions into a plan.</h2>
        <p class="mt-6 text-lg leading-relaxed text-primary-foreground/80">
          Most firms start by managing money and hope the rest of the picture works itself out. Keystone runs in the other order. It is a structured six-month engagement where we build the plan first, calibrate investments to it, and weave tax strategy through both. For retirement families, that usually means income, taxes, and investment decisions finally line up. For business owners, it means the business and personal plan stop being treated like separate projects.
        </p>
        <p class="mt-6 text-sm italic text-primary-foreground/70">Fully refundable at any point during the engagement, for any reason.</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/how-we-work/keystone-method" class="inline-flex rounded-md border border-primary-foreground/40 bg-primary-foreground/10 px-6 py-3 font-bold text-primary-foreground transition hover:bg-primary-foreground/20">See how Keystone works</a>
          <a href="/how-we-work/what-to-expect" class="inline-flex text-sm font-bold text-primary-foreground/75 transition hover:text-accent">Or see how the engagement actually unfolds</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-24">
    <div class="section-container">
      <div class="mx-auto grid max-w-5xl items-center gap-12 lg:grid-cols-2">
        <a href="/about/meet-david-talley" class="group block">
          <div class="aspect-[4/5] overflow-hidden rounded-lg shadow-elegant-xl">
            <img decoding="async" src="/brands/talley-wealth/david-talley.webp" alt="David Talley, CFP, ChFC, EA" class="h-full w-full object-cover transition duration-500 group-hover:scale-105"  loading="lazy" />
          </div>
        </a>

        <div>
          <div class="mb-6 flex items-center gap-3">
            <div class="gold-line"></div>
            <span class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Your Advisor</span>
          </div>
          <h2 class="font-serif text-3xl font-bold text-primary">David Talley</h2>
          <p class="mt-2 font-bold text-accent">CFP®, ChFC®, EA, Founder & Lead Advisor</p>
          <div class="mt-6 space-y-5 leading-relaxed text-muted-foreground">
            <p>The thing I see most often is successful people carrying more financial complexity than they want to carry alone. For many, that shows up as retirement getting close. For others, it shows up as a business that is finally profitable enough for tax and strategy questions to matter in a different way.</p>
            <p>I built Talley Wealth to do that work differently. Every client works directly with me. The plan, the investments, and the tax strategy sit in one conversation. Stephenee keeps the operational side running so the next steps stay visible, and meetings actually feel prepared rather than improvised.</p>
          </div>
          <a href="/about/meet-david-talley" class="mt-5 inline-flex text-sm font-bold text-muted-foreground transition hover:text-accent">The longer version of why I do this work</a>
          <div class="mt-8 flex flex-wrap gap-3">
            {['CFP®', 'ChFC®', 'EA'].map((credential) => (
              <span class="rounded-md bg-primary px-4 py-2 font-bold text-primary-foreground">{credential}</span>
            ))}
          </div>
          <div class="mt-8 flex items-center gap-4 border-t border-border pt-5">
            <div class="h-12 w-12 overflow-hidden rounded-full shadow-elegant">
              <img decoding="async" src="/brands/talley-wealth/stephenee-carberry.webp" alt="Stephenee Carberry, FPQP" class="h-full w-full object-cover"  loading="lazy" />
            </div>
            <div>
              <p class="text-sm font-bold text-primary">Supported by Stephenee Carberry, FPQP</p>
              <p class="text-xs text-muted-foreground">Practice Manager</p>
            </div>
          </div>
          <a href="/get-started" class="mt-8 inline-flex rounded-md bg-accent px-6 py-3 font-bold text-accent-foreground transition hover:bg-accent/90">Schedule an Explore Call</a>
        </div>
      </div>
    </div>
  </section>

  <TestimonialsSection />

  <CtaSection
    title="Ready to talk through what is on your mind?"
    description="A short conversation to understand what is on your mind, whether Keystone fits, and what should happen next."
    primaryText="Schedule Your Explore Call"
  />
</TalleyPage>

<style>
  @media (max-width: 640px) {
    .tw-home-hero__copy {
      width: min(100%, calc(100vw - 2rem));
      max-width: calc(100vw - 2rem);
    }

    section:first-of-type h1 {
      font-size: clamp(1.85rem, 9vw, 2.25rem);
      text-wrap: auto;
    }
  }
</style>
