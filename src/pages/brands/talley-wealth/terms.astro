---
import TalleyPage from '../../../components/talley-wealth/TalleyPage.astro';
---

<TalleyPage title="Terms of Service | Talley Wealth" description="Talley Wealth website terms of service." noindex>
  <section class="bg-muted/35 py-20">
    <div class="section-container">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Terms</p>
        <h1 class="mt-5 font-serif text-3xl font-bold text-primary md:text-4xl">Terms of Service</h1>
        <div class="mt-8 space-y-6 text-lg leading-relaxed text-muted-foreground">
          <p>This website is for general informational purposes only. Nothing on the site should be treated as individualized investment, tax, legal, or financial advice.</p>
          <p>Submitting a form does not create a client relationship. A client relationship begins only after the appropriate agreements are reviewed, signed, and accepted.</p>
          <p>External links, including third-party client portal links and Talley Tax, may take you to websites outside this platform. Talley Wealth is not responsible for the content or availability of external sites.</p>
          <p>For questions about these terms, contact <a href="mailto:hello@talleywealth.com" class="font-bold text-accent">hello@talleywealth.com</a>.</p>
        </div>
      </div>
    </div>
  </section>
</TalleyPage>
