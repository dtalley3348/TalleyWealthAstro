import { buildFAQPageSchema } from '../../../../data/talley-wealth/seo/schema';

type ServicePage = {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  intro: string;
  image: string;
  imageAlt: string;
  primaryTitle: string;
  primaryBody: string[];
  cardsTitle: string;
  cards: { title: string; body: string }[];
  listTitle: string;
  listItems: string[];
  stepsTitle?: string;
  steps?: { title: string; body: string }[];
  faqs?: { q: string; a: string }[];
  related?: { title: string; body: string; href: string }[];
  ctaTitle: string;
  ctaBody: string;
};

