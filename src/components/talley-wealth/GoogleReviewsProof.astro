---
import {
  AVERAGE_RATING,
  GOOGLE_REVIEWS_URL,
  selectedGoogleReviews,
  TESTIMONIAL_DISCLAIMER,
  TOTAL_REVIEW_COUNT,
} from '../../data/talley-wealth/reviews';

interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  reviewSet?: keyof typeof selectedGoogleReviews;
}

const {
  title = 'Clients often mention the same things.',
  description = 'The public reviews tend to come back to clarity, preparation, responsiveness, tax-aware planning, and feeling known by the team.',
  compact = false,
  reviewSet = 'default',
} = Astro.props;

const selected = selectedGoogleReviews[reviewSet] ?? selectedGoogleReviews.default;
const reviews = compact ? selected.slice(0, 2) : selected;
---

<section class="bg-card">
  <div class:list={['section-container', compact ? 'py-16' : 'py-24']}>
    <div class="grid gap-10 lg:grid-cols-[0.62fr_1fr] lg:items-start">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Public Google reviews</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">{title}</h2>
        <p class="mt-5 text-lg leading-relaxed text-muted-foreground">{description}</p>
        <div class="mt-7 inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 shadow-elegant">
          <span class="font-serif text-lg font-bold text-primary">{AVERAGE_RATING.toFixed(1)}</span>
          <span class="text-accent" aria-hidden="true">★★★★★</span>
          <span class="text-sm font-semibold text-muted-foreground">{TOTAL_REVIEW_COUNT} Google reviews</span>
        </div>
        <a href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex font-bold text-accent transition hover:text-accent/80">
          Read all Google reviews
          <span aria-hidden="true">&nbsp;-&gt;</span>
        </a>
      </div>

      <div class="grid gap-5">
        {reviews.map((review) => (
          <article class="rounded-lg border border-border/40 bg-background p-6 shadow-elegant">
            <p class="text-accent" aria-label="5 out of 5 stars">★★★★★</p>
            <blockquote class="mt-3 leading-relaxed text-foreground">&ldquo;{review.quote}&rdquo;</blockquote>
            <p class="mt-4 font-bold text-primary">{review.author}</p>
          </article>
        ))}
      </div>
    </div>
    <p class="mt-8 max-w-4xl text-xs leading-relaxed text-muted-foreground">
      {TESTIMONIAL_DISCLAIMER} Some longer public reviews may be excerpted for space. Read the full public review profile on Google.
    </p>
  </div>
</section>
