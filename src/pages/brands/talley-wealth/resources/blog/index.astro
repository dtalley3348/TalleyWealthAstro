---
import TalleyPage from '../../../../../components/talley-wealth/TalleyPage.astro';
import { blogPosts } from '../../../../../data/talley-wealth/site-content';
import { getBlogPosts, type DirectusBlogPost } from '../../../../../lib/directus';
import { assetUrl } from '../../../../../lib/asset-url';
import { normalizeBlogPost, deriveTags } from '../../../../../lib/talley-wealth/blog-content';

const DIRECTUS_PUBLIC_URL = import.meta.env.DIRECTUS_PUBLIC_URL || import.meta.env.DIRECTUS_URL || 'http://localhost:8055';
const directusPosts = await getBlogPosts({ siteKey: 'talley-wealth' });
const rawPosts = directusPosts.length > 0
  ? directusPosts.map((post: DirectusBlogPost) => ({
      slug: post.slug,
      title: post.title,
      description: post.excerpt,
      category: post.category,
      date: post.date_published,
      author: post.author,
      readTime: post.read_time,
      featured: post.featured,
      duration: post.duration,
      videoUrl: post.video_url,
      image: assetUrl(post.hero_image_url ?? post.hero_image, DIRECTUS_PUBLIC_URL, { width: 900, fit: 'cover', quality: 82 }) ?? '/brands/talley-wealth/blog/retirement-number-hero.jpg',
      body: String(post.body ?? '').split(/\n{2,}/).filter(Boolean),
    }))
  : blogPosts;
const posts = rawPosts.map((post) => normalizeBlogPost(post, rawPosts));
const activeTag = Astro.url.searchParams.get('tag') ?? '';
const postsForTag = activeTag ? posts.filter((post) => deriveTags(post).includes(activeTag)) : posts;
const featuredPost = activeTag ? null : posts.find((post) => post.featured) ?? posts[0];
const remainingPosts = activeTag ? postsForTag : posts.filter((post) => post.slug !== featuredPost?.slug);
const tags = Array.from(new Set(posts.flatMap((post) => deriveTags(post)))).slice(0, 12);
const planningAreas = [
  {
    title: 'Retirement decisions',
    body: 'Income, timing, taxes, healthcare, and market risk near retirement.',
    tag: 'Retirement Planning',
  },
  {
    title: 'Tax-aware planning',
    body: 'Roth conversions, RMDs, entity choices, and tax timing questions.',
    tag: 'Tax Planning',
  },
  {
    title: 'Investment questions',
    body: 'Portfolio decisions connected to actual goals rather than market noise.',
    tag: 'Investment Management',
  },
  {
    title: 'Business owner planning',
    body: 'Owner compensation, business cash flow, taxes, and personal planning overlap.',
    tag: 'Business Owners',
  },
].filter((area) => tags.includes(area.tag));
const relatedLinks = [
  {
    title: 'Planning tools',
    body: 'Use the calculators and visual tools when you want to see the concept, not only read about it.',
    href: '/resources/tools',
  },
  {
    title: 'Learning Center',
    body: 'Short answer-first explainers for retirement, tax, investing, and planning questions.',
    href: '/resources/learning-center',
  },
  {
    title: 'Retirement guide',
    body: 'A practical framework for retirement timing, taxes, income, and market risk.',
    href: '/guide',
  },
];
function formatDate(date: string) {
  const [year, month, day] = date.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<TalleyPage title="Resources and Blog | Talley Wealth" description="Planning, retirement, tax, and investment resources from Talley Wealth.">
  <section class="bg-muted/35">
    <div class="section-container py-16 md:py-20">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Blog</p>
      <h1 class="mt-5 font-serif text-4xl font-bold text-primary md:text-5xl">The Talley Perspective</h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        Straightforward thinking on taxes, retirement, investment decisions, and building a financial life that actually works.
      </p>

      {featuredPost && (
        <a href={`/resources/blog/${featuredPost.slug}`} class="mt-12 grid overflow-hidden rounded-lg border border-border bg-card shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg lg:grid-cols-[0.95fr_1.05fr]">
          <img decoding="async" src={featuredPost.image} alt={featuredPost.title} class="h-full min-h-[280px] w-full object-cover" loading="eager" />
          <div class="p-7 md:p-10">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">Featured / {featuredPost.category}</p>
            <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">{featuredPost.title}</h2>
            <p class="mt-5 text-lg leading-relaxed text-muted-foreground">{featuredPost.description}</p>
            <div class="mt-7 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-semibold text-muted-foreground">
              <span>{formatDate(featuredPost.date)}</span>
              <span aria-hidden="true">/</span>
              <span>{featuredPost.readTime}</span>
            </div>
          </div>
        </a>
      )}
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container py-16">
      <div class="flex flex-col gap-5 border-b border-border pb-8 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="font-serif text-3xl font-bold text-primary">{activeTag ? `${activeTag} Articles` : 'All Articles'}</h2>
          <p class="mt-2 text-muted-foreground">{activeTag ? 'Filtered to the planning area you selected.' : 'Use these as decision support, not market noise.'}</p>
        </div>
        <div class="flex flex-wrap gap-2">
          {activeTag && (
            <a href="/resources/blog" class="rounded-full border border-accent bg-accent px-4 py-2 text-sm font-semibold text-accent-foreground transition hover:bg-accent/90">All articles</a>
          )}
          {tags.map((tag) => (
            <a href={`/resources/blog?tag=${encodeURIComponent(tag)}`} class:list={[
              'rounded-full border px-4 py-2 text-sm font-semibold transition',
              activeTag === tag
                ? 'border-accent bg-accent text-accent-foreground'
                : 'border-border bg-card text-muted-foreground hover:border-accent hover:text-accent',
            ]}>{tag}</a>
          ))}
        </div>
      </div>

      {!activeTag && planningAreas.length > 0 && (
        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
          {planningAreas.map((area) => (
            <a href={`/resources/blog?tag=${encodeURIComponent(area.tag)}`} class="group rounded-lg border border-border bg-muted/30 p-5 transition hover:border-accent hover:bg-card">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">Browse by planning area</p>
              <h3 class="mt-3 font-serif text-xl font-bold text-primary transition group-hover:text-accent">{area.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{area.body}</p>
            </a>
          ))}
        </div>
      )}

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {remainingPosts.map((post) => (
          <a href={`/resources/blog/${post.slug}`} class="group flex h-full flex-col rounded-lg border border-border bg-card p-5 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <img decoding="async" src={post.image} alt={post.title} class="aspect-[4/3] w-full rounded-md object-cover" loading="lazy" />
            <p class="mt-5 text-xs font-bold uppercase tracking-[0.14em] text-accent">{post.category}</p>
            <h3 class="mt-2 font-serif text-2xl font-bold leading-tight text-primary">{post.title}</h3>
            <p class="mt-3 flex-1 text-muted-foreground">{post.description}</p>
            <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-semibold text-muted-foreground">
              <span>{formatDate(post.date)}</span>
              <span aria-hidden="true">/</span>
              <span>{post.readTime}</span>
            </div>
          </a>
        ))}
        {remainingPosts.length === 0 && (
          <div class="rounded-lg border border-border bg-card p-6 text-muted-foreground">
            No articles match this tag yet.
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="bg-card py-20">
    <div class="section-container">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">More resources</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">Different formats for different questions.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {relatedLinks.map((item) => (
          <a href={item.href} class="group rounded-lg border border-border bg-background p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <h3 class="font-serif text-xl font-bold text-primary transition group-hover:text-accent">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-accent">Explore <span aria-hidden="true">&nbsp;-&gt;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</TalleyPage>
