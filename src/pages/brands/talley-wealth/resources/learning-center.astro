---
import TalleyPage from '../../../../components/talley-wealth/TalleyPage.astro';
import { getArticleBySlug, wikiArticles } from '../../../../data/talley-wealth/wiki/articles';
import { wikiCategories } from '../../../../data/talley-wealth/wiki/categories';

const featuredSlugs = [
  'when-can-i-afford-to-retire',
  'roth-conversion-should-i',
  'what-is-asset-allocation',
  'what-estate-documents-do-i-need',
  'received-an-inheritance-what-now',
  'what-to-expect-first-meeting',
];
const featuredArticles = featuredSlugs
  .map((slug) => getArticleBySlug(slug))
  .filter((article): article is (typeof wikiArticles)[number] => Boolean(article));

const retirementQuestions = [
  {
    q: 'Can I actually stop working, and what changes if I wait?',
    a: 'Retirement timing can change healthcare, Social Security, taxes, withdrawals, cash reserves, and flexibility in the first few years.',
    href: '/five-retirement-questions-before-you-retire',
  },
  {
    q: 'Where does my paycheck come from after my paycheck stops?',
    a: 'The practical work is turning savings into a paycheck: which dollars come out first, which stay invested, and how much cash should stay available.',
    href: '/retirement-paycheck-planning-tri-cities-tn',
  },
  {
    q: 'What should my 401(k) be doing now that retirement is close?',
    a: 'The job changes from accumulation to income, guardrails, tax awareness, and protection against bad timing early in retirement.',
    href: '/retirement-paycheck-planning-tri-cities-tn',
  },
  {
    q: 'What tax decisions should I see before they are gone?',
    a: 'Roth conversions, charitable giving, withholding, HSA strategy, Social Security taxation, Medicare brackets, and withdrawal order are easier to evaluate before the calendar closes.',
    href: '/learn/tax-planning/roth-conversion-should-i',
  },
  {
    q: 'Would my spouse or family know what to do if I could not explain it?',
    a: 'Estate planning is not only documents. Accounts, beneficiaries, assets, and the documents need to line up before the family has to rely on them.',
    href: '/five-retirement-questions-before-you-retire',
  },
];
---

<TalleyPage
  title="Learning Center | Financial Planning FAQs | Talley Wealth"
  description="Short, clear answers to common retirement, tax, investment, and financial planning questions from Talley Wealth."
>
  <section class="bg-muted/35">
    <div class="section-container py-20">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Learning Center</p>
      <h1 class="mt-5 max-w-4xl break-words font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">Answers for the financial questions that do not fit neatly in one box.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        Start with the question on your mind. The useful answer is often not a rule of thumb, but seeing how taxes, investments, retirement income, estate planning, and real life affect each other.
      </p>
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container grid gap-10 border-b border-border/70 py-20 lg:grid-cols-[0.72fr_1.1fr] lg:items-start">
      <div class="max-w-xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Retirement starting point</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">Five questions that usually decide whether retirement feels ready.</h2>
        <p class="mt-5 max-w-lg text-lg leading-relaxed text-muted-foreground">
          If retirement is within sight, start here. Each question opens into a deeper answer, but the questions belong together because the decisions affect each other.
        </p>
        <a href="/financial-advisor-for-pre-retirees" class="mt-7 inline-flex rounded-md border border-accent/30 px-4 py-3 text-sm font-bold text-accent transition hover:border-accent hover:bg-accent hover:text-accent-foreground">
          See how we help pre-retirees -&gt;
        </a>
      </div>
      <ol class="grid gap-4">
        {retirementQuestions.map((item, index) => (
          <li class="min-w-0">
            <a href={item.href} class="group grid min-w-0 gap-4 rounded-lg border border-border/50 bg-card p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-accent/50 hover:shadow-elegant sm:grid-cols-[56px_1fr]">
              <span class="flex h-12 w-12 items-center justify-center rounded-md bg-accent/10 font-serif text-xl font-bold leading-none text-accent">{String(index + 1).padStart(2, '0')}</span>
              <span class="min-w-0">
                <span class="block break-words font-serif text-xl font-bold leading-snug text-primary transition group-hover:text-accent">{item.q}</span>
                <span class="mt-2 block break-words text-sm leading-relaxed text-muted-foreground">{item.a}</span>
                <span class="mt-4 inline-flex text-sm font-bold text-accent transition group-hover:translate-x-1">Read the deeper answer -&gt;</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="bg-background py-16">
    <div class="section-container">
      <div class="mb-10 max-w-3xl">
        <h2 class="font-serif text-3xl font-bold text-primary">Browse by topic</h2>
        <p class="mt-4 text-muted-foreground">These are grouped by decision, not by textbook chapter.</p>
      </div>

      <div class="grid min-w-0 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {wikiCategories.map((category) => (
          <a href={`/learn/${category.slug}`} class="min-w-0 rounded-lg border border-border bg-card p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{category.articleCount} articles</p>
            <h3 class="mt-3 break-words font-serif text-2xl font-bold text-primary">{category.title}</h3>
            <p class="mt-3 break-words leading-relaxed text-muted-foreground">{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-muted/25 py-16">
    <div class="section-container">
      <div class="mb-10 max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Start Here</p>
        <h2 class="mt-3 font-serif text-3xl font-bold text-primary">Questions that usually point to something deeper</h2>
      </div>

      <div class="grid min-w-0 gap-5 md:grid-cols-2 lg:grid-cols-3">
          {featuredArticles.map((article) => (
            <a href={`/learn/${article.category}/${article.slug}`} class="group min-w-0 rounded-lg border border-border bg-card p-6 shadow-elegant transition hover:-translate-y-1 hover:border-accent">
              <span class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{article.type.replace('-', ' ')}</span>
              <h3 class="mt-3 break-words font-serif text-xl font-bold leading-snug text-primary">{article.question}</h3>
              <p class="mt-3 line-clamp-4 break-words text-sm leading-relaxed text-muted-foreground">{article.quickAnswer}</p>
              <span class="mt-5 inline-flex text-sm font-bold text-accent transition group-hover:translate-x-1">Read answer -&gt;</span>
            </a>
          ))}
      </div>
    </div>
  </section>
</TalleyPage>
