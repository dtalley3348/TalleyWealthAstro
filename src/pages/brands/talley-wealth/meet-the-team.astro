---
import TalleyPage from '../../../components/talley-wealth/TalleyPage.astro';
import PageHero from '../../../components/talley-wealth/PageHero.astro';
import CtaSection from '../../../components/talley-wealth/CtaSection.astro';

const teamMembers = [
  {
    name: 'David Talley, CFP®, ChFC®, EA',
    role: 'Founder & Lead Advisor',
    image: '/brands/talley-wealth/david-talley.webp',
    bio: [
      "David leads the strategy and advice at Talley Wealth: recommendations, tax planning, investment alignment, and the major decisions that shape the work. His role is to help clients understand the tradeoffs clearly enough to make confident decisions.",
      'A Johnson City native, David combines more than a decade of experience in wealth and tax strategy with a genuine love for helping others build confidence in their financial lives. Outside the office, he enjoys golf, time outdoors with his family, and good books that challenge how he thinks.',
    ],
  },
  {
    name: 'Stephenee Carberry, FPQP',
    role: 'Practice Manager',
    image: '/brands/talley-wealth/stephenee-carberry.webp',
    bio: [
      "Stephenee helps keep the planning experience organized and responsive between meetings. She is often the best place to begin when clients have a question, need to schedule time, are sending documents, or want to understand what happens next.",
      "Originally from Johnson City and now based in Scottsdale, Arizona, Stephenee brings warmth, organization, and follow-through to the relationship. Her work helps clients feel that the details are being handled and the next step is clear.",
    ],
  },
];

const credentials = [
  { abbr: 'CFP®', full: 'Certified Financial Planner' },
  { abbr: 'ChFC®', full: 'Chartered Financial Consultant' },
  { abbr: 'EA', full: 'Enrolled Agent' },
  { abbr: 'FPQP', full: 'Financial Paraplanner Qualified Professional' },
];

---

<TalleyPage
  title="Meet the Team | Talley Wealth"
  description="Meet David Talley and Stephenee Carberry, the Talley Wealth team helping clients receive thoughtful advice and a well-run planning experience."
  ogImage="/brands/talley-wealth/hero-team-meeting.jpg"
>
  <PageHero
    label="Our Team"
    title="Meet the Team"
    description="A direct advisor relationship supported by careful follow-through, clear communication, and a planning experience that feels personal and well run."
  />

  <section class="bg-background">
    <div class="section-container py-24">
      <div class="mx-auto grid max-w-6xl items-start gap-12 lg:grid-cols-[0.72fr_1fr]">
        <div data-reveal="left">
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">How the relationship works</p>
          <h2 class="mt-4 font-serif text-3xl font-bold text-primary md:text-4xl">Built for direct advice and clear follow-through.</h2>
        </div>
        <div class="space-y-5 text-lg leading-relaxed text-muted-foreground" data-reveal="right">
          <p>
            Talley Wealth is built so the person leading the advice stays close to the work. Clients are not passed through layers of people who only know one part of the picture.
          </p>
          <p>
            David leads the strategy and advice. Stephenee helps make sure the experience around that advice is clear, organized, and responsive. The goal is a relationship that feels personal, prepared, and easy to keep track of.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card">
    <div class="section-container py-24">
      <div class="mx-auto max-w-4xl space-y-20">
        {teamMembers.map((member, index) => (
          <article class:list={['flex flex-col items-center gap-8 md:gap-12', index % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row']} data-reveal>
            <div class="w-full flex-shrink-0 md:w-2/5">
              <div class="aspect-[4/5] overflow-hidden rounded-2xl shadow-elegant-xl">
                <img decoding="async" src={member.image} alt={member.name} class="h-full w-full object-cover"  loading="lazy" />
              </div>
            </div>

            <div class="flex-1 text-center md:text-left">
              <h2 class="font-serif text-2xl font-bold text-primary md:text-3xl">{member.name}</h2>
              <p class="mt-2 font-semibold text-accent">{member.role}</p>
              <div class="mt-6 space-y-4 leading-relaxed text-muted-foreground">
                {member.bio.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card">
    <div class="section-container pb-24">
      <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 border-t border-border pt-10 text-center md:flex-row md:items-center md:text-left" data-reveal>
        <div class="w-28 flex-shrink-0 overflow-hidden rounded-xl bg-background p-1 shadow-elegant md:w-32">
          <img decoding="async" src="/brands/talley-wealth/daisy.webp" alt="Daisy at the Talley Wealth office" class="aspect-[2/3] h-full w-full rounded-lg object-contain" loading="lazy" />
        </div>
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Around the office</p>
          <h2 class="mt-2 font-serif text-2xl font-bold text-primary">You may also meet Daisy.</h2>
          <p class="mt-3 leading-relaxed text-muted-foreground">
            Daisy is often nearby in the Johnson City office, usually ready to greet visitors or settle into a quiet spot while the planning work happens.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container py-24">
      <div class="mx-auto max-w-3xl text-center">
        <div data-reveal>
          <h2 class="font-serif text-3xl font-bold text-primary">Professional Credentials</h2>
          <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
            Credentials are not a substitute for good advice or good service, but they matter. They reflect ongoing education and a shared responsibility to keep the work careful, current, and useful.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4">
          {credentials.map((cred) => (
            <article class="rounded-lg border border-border bg-card p-6 text-center shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg" data-reveal>
              <p class="font-serif text-2xl font-bold text-accent">{cred.abbr}</p>
              <p class="mt-2 text-sm text-muted-foreground">{cred.full}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary/30">
    <div class="section-container py-24">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h2 class="font-serif text-3xl font-bold text-primary">Our Fiduciary Commitment</h2>
        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
          When providing fiduciary advice, we are legally and ethically bound to act in your best interest. We also explain pricing and compensation before you decide whether to move forward, so the business side of the relationship is clear from the beginning.
        </p>
      </div>
    </div>
  </section>

  <CtaSection />
</TalleyPage>
