  <!-- Keep the review board running and bring it back if it stops. -->
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/davidtalley/Code/talley-wealth-astro-site-main/content-pipeline/work/review-server.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/davidtalley/Code/talley-wealth-astro-site-main/content-pipeline/work/review-server.log</string>
</dict>
</plist>
