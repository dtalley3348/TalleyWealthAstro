---
import TalleyPage from '../components/talley-wealth/TalleyPage.astro';

const nextSteps = [
  {
    title: 'Check your confirmation email',
    body: 'You should receive the calendar invite and call details shortly. If anything looks off, just reply or call the office.',
  },
  {
    title: 'Bring the question that prompted this',
    body: 'You do not need to organize documents before the call. The most useful starting point is the decision, concern, or loose end that made you schedule.',
  },
  {
    title: 'If it fits, we will explain the next step',
    body: 'The Explore Call is meant to see whether going further makes sense. If it does, we will talk through what that next step would look like.',
  },
];
---

<TalleyPage
  title="Explore Call Confirmed | Talley Wealth"
  description="Your Talley Wealth Explore Call has been scheduled."
  noindex
>
  <section class="bg-muted/35">
    <div class="section-container grid min-h-[640px] items-center gap-12 py-20 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <div class="mb-6 flex items-center gap-3">
          <div class="h-1 w-14 rounded-full bg-accent"></div>
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Explore Call Confirmed</p>
        </div>
        <h1 class="font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">
          You are scheduled.
        </h1>
        <div class="mt-6 max-w-2xl space-y-4 text-lg leading-relaxed text-muted-foreground">
          <p>
            Thanks for taking the time to schedule an Explore Call. There is nothing formal you need to prepare.
          </p>
          <p>
            Bring whatever is on your mind, and we will use the call to understand what brought you here and whether Talley Wealth is the right next step.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/explore-call-read" class="inline-flex rounded-md bg-accent px-5 py-3 font-bold text-accent-foreground transition hover:brightness-95">
            Read a Short Note Before We Talk
          </a>
          <a href="/" class="inline-flex rounded-md border border-border bg-card px-5 py-3 font-bold text-primary transition hover:border-accent hover:text-accent">
            Back to Homepage
          </a>
        </div>
      </div>

      <aside class="rounded-lg border border-border bg-card p-6 shadow-elegant md:p-8" aria-labelledby="next-steps-heading">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">What happens next</p>
        <h2 id="next-steps-heading" class="mt-3 font-serif text-3xl font-bold text-primary">
          A few simple notes before we talk.
        </h2>
        <div class="mt-7 space-y-4">
          {nextSteps.map((step, index) => (
            <article class="rounded-lg border border-border/50 bg-background p-5">
              <div class="flex gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-accent font-bold text-accent-foreground">
                  {index + 1}
                </span>
                <div>
                  <h3 class="font-serif text-xl font-bold text-primary">{step.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.body}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-7 rounded-lg bg-primary p-5 text-primary-foreground">
          <p class="font-serif text-xl font-bold">Need to reach us?</p>
          <p class="mt-2 text-sm leading-relaxed text-primary-foreground/80">Call the office and we will help you get oriented.</p>
          <a href="tel:+14236170160" class="mt-3 inline-flex font-bold text-accent">(423) 617-0160</a>
        </div>
      </aside>
    </div>
  </section>
</TalleyPage>
