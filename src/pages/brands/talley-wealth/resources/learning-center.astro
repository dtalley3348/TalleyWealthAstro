---
import TalleyPage from '../../../../components/talley-wealth/TalleyPage.astro';
import { wikiArticles } from '../../../../data/talley-wealth/wiki/articles';
import { wikiCategories } from '../../../../data/talley-wealth/wiki/categories';

const featuredArticles = wikiArticles.slice(0, 8);
---

<TalleyPage
  title="Learning Center | Financial Planning FAQs | Talley Wealth"
  description="Short, clear answers to common retirement, tax, investment, and financial planning questions from Talley Wealth."
>
  <section class="bg-muted/35">
    <div class="section-container py-20">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Learning Center</p>
      <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">Short answers to the financial questions people actually ask.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        The Learning Center is built for quick clarity: plain-English explanations, common planning questions, and links into deeper articles and tools when the topic needs more context.
      </p>
    </div>
  </section>

  <section class="bg-background py-20">
    <div class="section-container">
      <div class="mb-12 max-w-3xl">
        <h2 class="font-serif text-3xl font-bold text-primary">Browse by topic</h2>
        <p class="mt-4 text-muted-foreground">Start with a category, or jump into a popular question below.</p>
      </div>

      <div class="mb-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {wikiCategories.map((category) => (
          <a href={`/learn/${category.slug}`} class="rounded-lg border border-border bg-card p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{category.articleCount} articles</p>
            <h3 class="mt-3 font-serif text-2xl font-bold text-primary">{category.title}</h3>
            <p class="mt-3 leading-relaxed text-muted-foreground">{category.description}</p>
          </a>
        ))}
      </div>

      <div class="rounded-lg border border-border bg-card p-8 shadow-elegant">
        <h2 class="font-serif text-2xl font-bold text-primary">Popular questions</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {featuredArticles.map((article) => (
            <a href={`/learn/${article.category}/${article.slug}`} class="group flex items-start gap-3 rounded-lg border border-border bg-background p-4 transition hover:border-accent">
              <span class="mt-1 text-accent transition group-hover:translate-x-1">-&gt;</span>
              <span class="text-sm font-semibold text-foreground transition group-hover:text-primary">{article.question}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</TalleyPage>
