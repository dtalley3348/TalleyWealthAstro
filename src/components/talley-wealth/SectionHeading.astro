---
interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
  inverted?: boolean;
}

const { label, title, description, align = 'center', class: className = '', inverted = false } = Astro.props;
---

<div
  data-reveal
  class:list={[
    'max-w-3xl',
    align === 'center' && 'mx-auto text-center',
    className,
  ]}
>
  {label && (
    <div class:list={['mb-4 flex items-center gap-3', align === 'center' && 'justify-center']}>
      <span class="gold-line"></span>
      <span class="text-sm font-semibold uppercase tracking-wider text-accent">{label}</span>
      {align === 'center' && <span class="gold-line"></span>}
    </div>
  )}
  <h2 class:list={['mb-4 font-serif text-3xl font-bold md:text-4xl', inverted ? 'text-primary-foreground' : 'text-primary']}>
    <Fragment set:html={title} />
  </h2>
  {description && (
    <p class:list={['text-lg leading-relaxed', inverted ? 'text-white/70' : 'text-muted-foreground']}>
      {description}
    </p>
  )}
</div>
