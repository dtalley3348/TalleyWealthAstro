---
import TalleyPage from '../../../../components/talley-wealth/TalleyPage.astro';
import { wikiArticles } from '../../../../data/talley-wealth/wiki/articles';
import { getCategoryBySlug } from '../../../../data/talley-wealth/wiki/categories';


const categorySlug = Astro.params.category ?? '';
const category = getCategoryBySlug(categorySlug);
const articles = wikiArticles.filter((article) => article.category === categorySlug);
if (!category || !articles.length) return new Response('Not found', { status: 404 });
---

<TalleyPage title={`${category.title} | Talley Wealth Knowledge Base`} description={category.description}>
  <section class="bg-muted/35">
    <div class="section-container py-20">
      <a href="/resources/learning-center" class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Learning Center</a>
      <h1 class="mt-5 break-words font-serif text-4xl font-bold text-primary md:text-5xl">{category.title}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-muted-foreground">{category.description}</p>
    </div>
  </section>

  <section class="bg-background py-20">
    <div class="section-container">
      <div class="grid min-w-0 gap-5 md:grid-cols-2">
        {articles.map((article) => (
          <a href={`/learn/${article.category}/${article.slug}`} class="group min-w-0 rounded-lg border border-border/40 bg-card p-6 shadow-elegant transition hover:-translate-y-1 hover:border-accent hover:shadow-elegant-lg">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{article.type.replace('-', ' ')}</p>
            <h2 class="mt-3 break-words font-serif text-2xl font-bold leading-tight text-primary">{article.question}</h2>
            <p class="mt-3 line-clamp-3 break-words leading-relaxed text-muted-foreground">{article.quickAnswer}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-accent transition group-hover:translate-x-1">Read answer -&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</TalleyPage>
