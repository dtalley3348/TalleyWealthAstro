        </div>
      </aside>
    </div>
  </article>
  )}
</TalleyPage>

<script>
  document.querySelectorAll('[data-seek-seconds]').forEach((button) => {
    button.addEventListener('click', () => {
      const seconds = Number(button.getAttribute('data-seek-seconds') || 0);
      const video = document.getElementById('tw-source-video');
      if (video instanceof HTMLVideoElement) {
        video.currentTime = Math.max(0, seconds);
        video.play().catch(() => {});
        const frame = document.getElementById('tw-source-video-frame') || video;
        frame.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  });
  document.querySelectorAll('video[data-start-seconds]').forEach((video) => {
    if (!(video instanceof HTMLVideoElement)) return;
    const start = Number(video.getAttribute('data-start-seconds') || 0);
    const seek = () => {
      if (Number.isFinite(start) && start > 0 && Math.abs(video.currentTime - start) > 0.5) {
        video.currentTime = start;
      }
    };
    video.addEventListener('loadedmetadata', seek, { once: true });
    video.addEventListener('play', seek, { once: true });
  });
</script>

