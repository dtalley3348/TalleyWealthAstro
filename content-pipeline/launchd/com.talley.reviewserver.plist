<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.talley.reviewserver</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/Users/davidtalley/Code/talley-wealth-astro-site-main/content-pipeline/scripts/review-server.mjs</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/davidtalley/Code/talley-wealth-astro-site-main/content-pipeline</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
