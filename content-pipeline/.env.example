# Local Phase 2 drafting
# Copy to .env and fill in locally. Do not commit real keys.
OPENAI_API_KEY=
# Optional. Defaults to gpt-4.1 in scripts/draft-content.mjs if unset.
OPENAI_MODEL=gpt-4.1

# Metricool scheduling integration. Keep real values only in .env.
METRICOOL_API_KEY=
METRICOOL_USER_ID=
METRICOOL_BRAND_ID=
# Optional multi-brand IDs. Leave blank until each Brand exists in Metricool.
# Scripts still use METRICOOL_BRAND_ID as the Talley Wealth fallback.
METRICOOL_BRAND_ID_TALLEY_WEALTH=
METRICOOL_BRAND_ID_TALLEY_TAX=
METRICOOL_BRAND_ID_RETIRE_WITH_TALLEY=
METRICOOL_BRAND_ID_DAVID_TALLEY_PERSONAL=
METRICOOL_DRY_RUN=true
# Extra live-write kill switch. Leave false unless intentionally running
# scripts/metricool-live.mjs with --confirm-live.
METRICOOL_LIVE_WRITE=false
# auto = include X only when scripts/sync-metricool-status.mjs sees X connected on the active brand.
# true/false can force it for local testing.
METRICOOL_ENABLE_X=auto
METRICOOL_TIMEZONE=America/New_York

# Optional media staging for Metricool video/carousel posts.
# prepare-metricool-media.mjs copies approved files here and derives public URLs.
# The files still need to be deployed/served at METRICOOL_MEDIA_BASE_URL before
# live media scheduling can succeed.
METRICOOL_MEDIA_PUBLIC_DIR=../public/pipeline-media
METRICOOL_MEDIA_BASE_URL=https://talleywealth.com/pipeline-media

# Recommended long-term media host: separate Cloudflare R2 bucket.
# This does not require moving talleywealth.com or changing the website.
# R2_PUBLIC_BASE_URL can start as Cloudflare's public bucket URL, then later move
# to a custom media subdomain only if desired.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=talley-pipeline-media
R2_PUBLIC_BASE_URL=
R2_KEY_PREFIX=talley-pipeline
