Object.assign(pages, canonicalPlanningPages);

export function getStaticPaths() {
  return Object.keys(pages).map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug ?? '';
const page = pages[slug];
if (!page) return new Response('Not found', { status: 404 });
---

<TalleyPage title={page.title} description={page.description} ogImage={page.image} jsonLd={page.faqs ? buildFAQPageSchema(page.faqs) : undefined}>
  <section class="bg-muted/35">
    <div class="section-container grid min-h-[620px] items-center gap-12 py-20 lg:grid-cols-[0.95fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">{page.eyebrow}</p>
        <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">{page.heading}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">{page.intro}</p>
      </div>
      <div class="overflow-hidden rounded-xl border-[14px] border-primary/15 shadow-elegant-lg">
        <img decoding="async" src={page.image} alt={page.imageAlt} class="aspect-[4/3] w-full object-cover" loading="eager" />
      </div>
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container grid gap-12 py-20 lg:grid-cols-[0.76fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">How this fits</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">{page.primaryTitle}</h2>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-muted-foreground">
        {page.primaryBody.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="bg-card">
    <div class="section-container py-20">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">{page.cardsTitle}</p>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {page.cards.map((item) => (
          <article class="rounded-lg border border-border bg-background p-6 shadow-elegant">
            <h2 class="font-serif text-2xl font-bold text-primary">{item.title}</h2>
            <p class="mt-4 leading-relaxed text-muted-foreground">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background">
    <div class="section-container grid gap-12 py-20 lg:grid-cols-[0.75fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Details</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">{page.listTitle}</h2>
      </div>
      <ul class="grid gap-3 sm:grid-cols-2">
        {page.listItems.map((item) => (
          <li class="rounded-md border border-border bg-card p-4 text-sm font-semibold leading-relaxed text-primary shadow-sm">{item}</li>
        ))}
      </ul>
    </div>
  </section>

  {page.steps && (
    <section class="bg-muted/30">
      <div class="section-container py-20">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">{page.stepsTitle}</p>
        <div class="mt-8 grid gap-5 md:grid-cols-5">
          {page.steps.map((step, index) => (
            <article class="rounded-lg border border-border bg-card p-5 shadow-sm">
              <p class="font-serif text-3xl font-bold text-accent">{String(index + 1).padStart(2, '0')}</p>
              <h2 class="mt-3 font-serif text-xl font-bold text-primary">{step.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.faqs && (
    <section class="bg-muted/30">
      <div class="section-container max-w-4xl py-20">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Common questions</p>
        <div class="tw-faq-list mt-8" data-reveal>
          {page.faqs.map((faq) => (
            <details class="tw-faq-item">
              <summary>
                <span>{faq.q}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
              </summary>
              <div class="tw-faq-answer"><p>{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.related && (
    <section class="bg-card">
      <div class="section-container py-20">
        <div class="mx-auto mb-10 max-w-3xl text-center">
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Continue exploring</p>
          <h2 class="mt-4 font-serif text-3xl font-bold leading-tight text-primary md:text-4xl">Related next pages</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {page.related.map((item) => (
            <a href={item.href} class="group rounded-lg border border-border bg-background p-6 shadow-elegant transition hover:-translate-y-1 hover:shadow-elegant-lg">
              <h3 class="font-serif text-2xl font-bold text-primary transition group-hover:text-accent">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
              <span class="mt-5 inline-flex text-sm font-bold text-accent">Read more <span aria-hidden="true">&nbsp;-&gt;</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="bg-primary text-primary-foreground">
    <div class="section-container grid gap-10 py-20 lg:grid-cols-[0.8fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Next step</p>
        <h2 class="mt-4 font-serif text-3xl font-bold leading-tight md:text-4xl">{page.ctaTitle}</h2>
        <p class="mt-5 text-lg leading-relaxed text-white/78">{page.ctaBody}</p>
      </div>
      <CalendlyEmbed source={`services-${slug}`} title="Schedule an Explore Call" description="Choose a time that works for you. No prep needed." />
    </div>
  </section>
</TalleyPage>
