---
import TalleyPage from '../../../../../components/talley-wealth/TalleyPage.astro';
import { blogPosts, blogPostMap, previewBlogPostMap } from '../../../../../data/talley-wealth/site-content';
import { getBlogPost, getBlogPosts, type DirectusBlogPost } from '../../../../../lib/directus';
import { assetUrl } from '../../../../../lib/asset-url';
import { buildBlogPostingSchema } from '../../../../../data/talley-wealth/seo/schema';
import { normalizeBlogPost, type BlogContentBlock } from '../../../../../lib/talley-wealth/blog-content';
import { getInternalLinks } from '../../../../../data/talley-wealth/seo/internal-links';
import { blogStrategyBySlug } from '../../../../../data/talley-wealth/blog-strategy';

const DIRECTUS_PUBLIC_URL = import.meta.env.DIRECTUS_PUBLIC_URL || import.meta.env.DIRECTUS_URL || 'http://localhost:8055';

function formatDate(date: string) {
  const [year, month, day] = date.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function formatAuthor(author?: string | null) {
  const value = String(author || '').trim();
  if (!value || /^david talley$/i.test(value)) return 'David Talley, CFP®, EA';
  return value;
}

function escapeHtml(value: string) {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function inlineHtml(value: string) {
  return escapeHtml(value)
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, label, href) => {
      const safeHref = String(href).startsWith('/') || String(href).startsWith('https://') ? href : '#';
      return `<a href="${safeHref}">${label}</a>`;
    });
}

function headingId(value: string) {
  return value
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .slice(0, 80);
}

function stripWrappingQuotes(value: string) {
  return value.replace(/^["“]/, '').replace(/["”]$/, '');
}

function isPullQuoteText(value: string) {
  const cleaned = value.trim();
  if (/^["“].+["”]$/.test(cleaned) && cleaned.length < 240) return true;
  if (cleaned.length > 180) return false;
  return [
    'Same balance.',
    'Same withdrawals.',
    'Completely different outcomes.',
    'You cannot control the sequence.',
    'A plan that looks good on paper',
  ].some((phrase) => cleaned.includes(phrase));
}

function videoEmbedUrl(videoUrl?: string | null) {
  if (!videoUrl) return null;
  const youtube = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]+)/);
  if (youtube) return `https://www.youtube.com/embed/${youtube[1]}`;
  const vimeo = videoUrl.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return null;
}

function nativeVideoUrl(videoUrl?: string | null) {
  if (!videoUrl) return null;
  if (/\.(mp4|webm|mov)(\?.*)?$/i.test(videoUrl)) return videoUrl;
  if (videoUrl.startsWith('/')) return videoUrl;
  return null;
}

function momentId(seconds: number) {
  return `source-moment-${Math.max(0, Math.round(Number(seconds) || 0))}`;
}


const slug = Astro.params.slug ?? '';
const isPreviewRuntime = import.meta.env.DEV || import.meta.env.PUBLIC_ENABLE_CONTENT_PREVIEWS === 'true';
const directusPost = import.meta.env.DIRECTUS_URL || import.meta.env.DIRECTUS_PUBLIC_URL
  ? await getBlogPost(slug, 'talley-wealth')
  : null;
const publicFallbackPost = blogPostMap.get(slug);
const previewFallbackPost = isPreviewRuntime ? previewBlogPostMap.get(slug) : undefined;
const fallbackPost = publicFallbackPost ?? previewFallbackPost;
const isPreviewPost = !publicFallbackPost && !!previewFallbackPost;
const directusPosts = import.meta.env.DIRECTUS_URL || import.meta.env.DIRECTUS_PUBLIC_URL
  ? await getBlogPosts({ siteKey: 'talley-wealth' })
  : [];
const relatedSourcePosts = directusPosts.length > 0
  ? directusPosts.map((post: DirectusBlogPost) => ({
      slug: post.slug,
      title: post.title,
      description: post.excerpt,
      category: post.category,
      date: post.date_published,
      image: assetUrl(post.hero_image_url ?? post.hero_image, DIRECTUS_PUBLIC_URL, { width: 900, fit: 'cover', quality: 82 }) ?? '/brands/talley-wealth/blog/retirement-number-hero.jpg',
      author: post.author,
      readTime: post.read_time,
      featured: post.featured,
      duration: post.duration,
      videoUrl: post.video_url,
      body: String(post.body ?? '').split(/\n{2,}/).filter(Boolean),
    }))
  : isPreviewRuntime
    ? Array.from(previewBlogPostMap.values())
    : blogPosts;
const rawPost = directusPost
  ? {
      title: directusPost.title,
      description: directusPost.excerpt,
      category: directusPost.category,
      date: directusPost.date_published,
      image: assetUrl(directusPost.hero_image_url ?? directusPost.hero_image, DIRECTUS_PUBLIC_URL, { width: 1200, fit: 'cover', quality: 84 }) ?? '/brands/talley-wealth/blog/retirement-number-hero.jpg',
      author: directusPost.author,
      readTime: directusPost.read_time,
      featured: directusPost.featured,
      duration: directusPost.duration,
      videoUrl: directusPost.video_url,
      body: String(directusPost.body ?? '').split(/\n{2,}/).filter(Boolean),
    }
  : fallbackPost;
if (!rawPost) return new Response('Not found', { status: 404 });
const post = normalizeBlogPost({ slug, ...rawPost }, relatedSourcePosts);
const displayAuthor = formatAuthor(post.author);
const isRichResource = post.contentKind === 'video_explainer_page' || post.layoutVariant === 'rich_resource_page';
const strategy = blogStrategyBySlug[slug];
const internalLinks = strategy?.links ?? getInternalLinks([post.category, post.title, post.description, ...post.tags], 4);
const planningLinks = internalLinks.map((link) => ({
  label: link.title,
  href: link.href,
}));
const embedUrl = videoEmbedUrl(post.videoUrl);
const nativeVideo = nativeVideoUrl(post.videoUrl);
const sourceMoments = (post.sourceMoments || []).slice(0, 3);
const hasSourceMoments = sourceMoments.length > 0;
const useVideoHero = Boolean(nativeVideo && (isPreviewPost || isRichResource || hasSourceMoments));
const canonicalUrl = new URL(`/resources/blog/${slug}`, Astro.site ?? Astro.url.origin).href;
const cta = strategy?.cta ?? (post.category.toLowerCase().includes('retirement')
  ? { eyebrow: 'Retirement guide', title: 'Want a clearer way to think about your number?', body: 'The retirement guide walks through the real inputs: spending, taxes, timing, risk, and the decisions that shape whether the plan holds up.', href: '/guide', label: 'Download the free guide' }
  : { eyebrow: 'Next step', title: 'Want to see how this applies to your situation?', body: 'An Explore Call is a short conversation to understand what is on your mind and whether our planning process fits.', href: '/get-started', label: 'Schedule an Explore Call' });
const articleToolCallout = slug === 'should-i-elect-s-corp-status'
  ? {
      eyebrow: 'Decision guide',
      title: 'Want the structured S-Corp planning page?',
      body: 'Use the decision guide when you want the fit questions, Tennessee nuance, reasonable compensation, and visual in one place.',
      href: '/s-corp-planning-tri-cities-tn',
      label: 'Open the S-Corp guide',
    }
  : null;
const tableOfContents = post.bodyBlocks
  .filter((block): block is Extract<BlogContentBlock, { type: 'heading' }> => block.type === 'heading' && block.level === 2)
  .map((block) => ({ text: block.text, id: headingId(block.text) }));
let paragraphCount = 0;
const articleBlocks = post.bodyBlocks.map((block) => {
  if (block.type === 'heading') return { ...block, id: headingId(block.text) };
  if (block.type !== 'paragraph') return block;
  paragraphCount += 1;
  return {
    ...block,
    text: isPullQuoteText(block.text) ? stripWrappingQuotes(block.text) : block.text,
    isLead: paragraphCount === 1,
    isPullQuote: paragraphCount !== 1 && isPullQuoteText(block.text),
  };
});
const answerBlockIndex = articleBlocks.findIndex((block) => block.type === 'paragraph');
const answerBlock = answerBlockIndex >= 0 ? articleBlocks[answerBlockIndex] : null;
const resourceArticleBlocks = articleBlocks.filter((_block, index) => index !== answerBlockIndex);
const sourceVideoWithTime = (seconds: number) => nativeVideo
  ? `${nativeVideo}#t=${Math.max(0, Math.round(Number(seconds) || 0))}`
  : '';
const resourceSpec = post.resourceSpec;
const heroDeck = resourceSpec?.deck || post.description;
const resourceSpecToc = resourceSpec ? [
  { text: 'Short answer', id: 'short-answer' },
  resourceSpec.situation && { text: resourceSpec.situation.title || 'The situation', id: 'situation' },
  resourceSpec.deeperProblem && { text: resourceSpec.deeperProblem.title || 'Deeper problem', id: 'deeper-problem' },
  resourceSpec.framework && { text: resourceSpec.framework.title || 'Decision framework', id: 'framework' },
  hasSourceMoments && { text: 'Source moment', id: 'source-moments-heading' },
  resourceSpec.valueBlock && { text: resourceSpec.valueBlock.title || 'Planning checklist', id: 'value-block' },
  resourceSpec.faqs?.length && { text: 'Follow-up questions', id: 'faq' },
].filter(Boolean) as { text: string; id: string }[] : [];
const shouldHideFromSearch = isPreviewPost || post.publicationStatus === 'preview' || post.publicationStatus === 'approved';
---

<TalleyPage title={`${post.title} | Talley Wealth`} description={post.description} ogImage={post.image} ogType="article" noindex={shouldHideFromSearch} nofollow={shouldHideFromSearch} jsonLd={buildBlogPostingSchema({ title: post.title, description: post.description, datePublished: post.date, image: post.image, url: canonicalUrl, author: displayAuthor, videoUrl: post.videoUrl, sourceMoments })}>
  {isRichResource ? (
    <article class="tw-resource-page">
      <header class="tw-resource-hero">
        <img src={post.image} alt={post.title} decoding="async" loading="eager" />
        <div class="tw-resource-hero__inner">
          <a href="/resources/blog" class="tw-resource-back">Back to Blog</a>
          <p class="tw-resource-eyebrow">{post.category}</p>
          <h1>{post.title}</h1>
          <p class="tw-resource-deck">{heroDeck}</p>
          <div class="tw-resource-meta">
            <span>By {displayAuthor}</span>
            <span>{formatDate(post.date)}</span>
            <span>{post.readTime}</span>
            {isPreviewPost && <span>Local draft preview</span>}
          </div>
        </div>
      </header>

      <main class="tw-resource-shell">
        {resourceSpec ? (
          <>
            <article class="tw-resource-article">
              <section class="tw-answer-box" id="short-answer">
                <p class="tw-answer-label">Short Answer</p>
                <p set:html={inlineHtml(resourceSpec.shortAnswer || post.description)} />
              </section>

              <div class="tw-resource-body">
                {resourceSpec.intro?.map((paragraph) => <p class="tw-resource-lead" set:html={inlineHtml(paragraph)} />)}

                {resourceSpec.situation && (
                  <section id="situation">
                    <h2>{resourceSpec.situation.title || 'The Situation Behind The Question'}</h2>
                    {resourceSpec.situation.body?.map((paragraph) => <p set:html={inlineHtml(paragraph)} />)}
                  </section>
                )}

                {resourceSpec.deeperProblem && (
                  <section id="deeper-problem">
                    <h2>{resourceSpec.deeperProblem.title || 'The Deeper Problem'}</h2>
                    <div class="tw-feature-grid">
                      {resourceSpec.deeperProblem.surfaceQuestion && (
                        <div class="tw-feature">
                          <strong>Surface question</strong>
                          <span set:html={inlineHtml(resourceSpec.deeperProblem.surfaceQuestion)} />
                        </div>
                      )}
                      {resourceSpec.deeperProblem.deeperQuestion && (
                        <div class="tw-feature">
                          <strong>Deeper question</strong>
                          <span set:html={inlineHtml(resourceSpec.deeperProblem.deeperQuestion)} />
                        </div>
                      )}
                      {resourceSpec.deeperProblem.whyItMatters && (
                        <div class="tw-feature">
                          <strong>Why it matters</strong>
                          <span set:html={inlineHtml(resourceSpec.deeperProblem.whyItMatters)} />
                        </div>
                      )}
                    </div>
                  </section>
                )}

                {resourceSpec.framework && (
                  <section id="framework">
                    <h2>{resourceSpec.framework.title || 'A Better Decision Framework'}</h2>
                    {resourceSpec.framework.intro && <p set:html={inlineHtml(resourceSpec.framework.intro)} />}
                    <div class="tw-framework">
                      {resourceSpec.framework.steps?.map((step, index) => (
                        <article class="tw-factor">
                          <div class="tw-number">{index + 1}</div>
                          <div>
                            <h3 set:html={inlineHtml(step.title)} />
                            <p set:html={inlineHtml(step.body)} />
                          </div>
                        </article>
                      ))}
                    </div>
                  </section>
                )}
              </div>

              {hasSourceMoments && nativeVideo && (
                <section class="tw-source-moments tw-source-moments--resource" aria-labelledby="source-moments-heading">
                  <p class="tw-resource-section-label">Source moment</p>
                  <h2 id="source-moments-heading">Watch the part that answers the key question</h2>
                  <div class="tw-source-moment-list">
                    {sourceMoments.slice(0, 2).map((moment) => (
                      <article id={momentId(moment.seconds)} class="tw-source-moment-card">
                        <div class="tw-source-moment-media">
                          <video
                            controls
                            preload="metadata"
                            src={sourceVideoWithTime(moment.seconds)}
                            data-start-seconds={moment.seconds}
                            aria-label={`${moment.label} source video starting at ${moment.timestamp}`}
                          />
                        </div>
                        <div class="tw-source-moment-copy">
                          <p class="tw-source-time">Starts at {moment.timestamp}</p>
                          <h3>{moment.question || moment.label}</h3>
                          {moment.answer && <p>{moment.answer}</p>}
                          {moment.transcriptExcerpt && <blockquote>{moment.transcriptExcerpt}</blockquote>}
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              )}

              {resourceSpec.quote && (
                <aside class="tw-resource-quote">
                  <p set:html={inlineHtml(`"${resourceSpec.quote.text}"`)} />
                  {resourceSpec.quote.cite && <cite>{resourceSpec.quote.cite}</cite>}
                </aside>
              )}

              <div class="tw-resource-body">
                {resourceSpec.valueBlock && (
                  <section id="value-block" class:list={[resourceSpec.valueBlock.type === 'checklist' && 'tw-checklist']}>
                    <h2>{resourceSpec.valueBlock.title || 'Questions To Bring To A Planning Conversation'}</h2>
                    {resourceSpec.valueBlock.intro && <p set:html={inlineHtml(resourceSpec.valueBlock.intro)} />}
                    {resourceSpec.valueBlock.type === 'checklist' ? (
                      <ul>
                        {resourceSpec.valueBlock.items?.map((item) => <li set:html={inlineHtml(item)} />)}
                      </ul>
                    ) : (
                      <div class="tw-table-wrap">
                        <table>
                          <thead>
                            <tr>{resourceSpec.valueBlock.columns?.map((column) => <th set:html={inlineHtml(column)} />)}</tr>
                          </thead>
                          <tbody>
                            {resourceSpec.valueBlock.rows?.map((row) => (
                              <tr>{row.map((cell) => <td set:html={inlineHtml(cell)} />)}</tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    )}
                  </section>
                )}

                {resourceSpec.risks && (
                  <section id="risks">
                    <h2>{resourceSpec.risks.title || 'Risks And Limits'}</h2>
                    {resourceSpec.risks.body?.map((paragraph) => <p set:html={inlineHtml(paragraph)} />)}
                  </section>
                )}

                {resourceSpec.faqs?.length ? (
                  <section id="faq">
                    <h2>Follow-Up Questions</h2>
                    <div class="tw-faq">
                      {resourceSpec.faqs.map((item) => (
                        <details>
                          <summary set:html={inlineHtml(item.question)} />
                          <p set:html={inlineHtml(item.answer)} />
                        </details>
                      ))}
                    </div>
                  </section>
                ) : null}

                {resourceSpec.relatedLinks?.length ? (
                  <section id="links">
                    <h2>Related Talley Wealth Resources</h2>
                    <p>If this question is on your mind, these pages are natural next reads:</p>
                    <ul>
                      {resourceSpec.relatedLinks.map((link) => <li><a href={link.href}>{link.title}</a></li>)}
                    </ul>
                  </section>
                ) : null}
              </div>

              <section class="tw-resource-cta">
                <div>
                  <p class="tw-resource-section-label">{cta.eyebrow}</p>
                  <h2>{resourceSpec.cta?.title || cta.title}</h2>
                  <p>{resourceSpec.cta?.body || cta.body}</p>
                </div>
                <a href={resourceSpec.cta?.href || cta.href}>{resourceSpec.cta?.label || cta.label}</a>
              </section>

              {resourceSpec.disclaimer && <p class="tw-fine-print">{resourceSpec.disclaimer}</p>}
            </article>

            <aside class="tw-resource-sidebar" aria-label="Article navigation and source">
              <section class="tw-side-panel">
                <h2>Article Map</h2>
                <ul class="tw-resource-toc">
                  {resourceSpecToc.map((item) => <li><a href={`#${item.id}`}>{item.text}</a></li>)}
                </ul>
              </section>

              {nativeVideo && (
                <section class="tw-side-panel">
                  <h3>Source Video</h3>
                  <video class="tw-mini-video tw-mini-video--landscape" controls preload="metadata" src={nativeVideo} />
                  <p>This preview is adapted from a short Talley Wealth educational video and rewritten as a durable article.</p>
                </section>
              )}

              <section class="tw-side-panel">
                <h3>Why This Was Picked</h3>
                <p>{post.description}</p>
              </section>
            </aside>
          </>
        ) : (
          <>
            <article class="tw-resource-article">
              {answerBlock && answerBlock.type === 'paragraph' && (
                <section class="tw-answer-box" id="short-answer">
                  <p class="tw-answer-label">Short Answer</p>
                  <p set:html={inlineHtml(answerBlock.text)} />
                </section>
              )}

              <div class="tw-resource-body">
                {resourceArticleBlocks.map((block) => (
                  <>
                    {block.type === 'heading' && block.level === 2 && <h2 id={block.id} set:html={inlineHtml(block.text)} />}
                    {block.type === 'heading' && block.level === 3 && <h3 id={block.id} set:html={inlineHtml(block.text)} />}
                    {block.type === 'paragraph' && block.isPullQuote && (
                      <aside class="tw-resource-quote">
                        <p set:html={inlineHtml(block.text)} />
                      </aside>
                    )}
                    {block.type === 'paragraph' && !block.isPullQuote && <p class:list={[block.isLead && 'tw-resource-lead']} set:html={inlineHtml(block.text)} />}
                    {block.type === 'quote' && <blockquote><p set:html={inlineHtml(block.text)} /></blockquote>}
                    {block.type === 'list' && (
                      <ul>
                        {block.items.map((item) => <li set:html={inlineHtml(item)} />)}
                      </ul>
                    )}
                  </>
                ))}
              </div>

              <section class="tw-resource-cta">
                <div>
                  <p class="tw-resource-section-label">{cta.eyebrow}</p>
                  <h2>{cta.title}</h2>
                  <p>{cta.body}</p>
                </div>
                <a href={cta.href}>{cta.label}</a>
              </section>
            </article>

            <aside class="tw-resource-sidebar" aria-label="Article navigation and source">
              {tableOfContents.length > 0 && (
                <section class="tw-side-panel">
                  <h2>Article Map</h2>
                  <ul class="tw-resource-toc">
                    {answerBlock && <li><a href="#short-answer">Short answer</a></li>}
                    {tableOfContents.slice(0, 7).map((item) => (
                      <li><a href={`#${item.id}`}>{item.text}</a></li>
                    ))}
                  </ul>
                </section>
              )}

              <section class="tw-side-panel">
                <h3>Why This Was Picked</h3>
                <p>{post.description}</p>
              </section>
            </aside>
          </>
        )}
      </main>
    </article>
  ) : (
  <article class="bg-background">
    <header class="bg-muted/35">
      <div class:list={[
        'section-container grid gap-10 py-16 lg:items-end',
        useVideoHero
          ? 'lg:grid-cols-[minmax(0,0.9fr)_minmax(320px,0.58fr)]'
          : 'lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.65fr)]',
      ]}>
        <div>
          <a href="/resources/blog" class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Back to Blog</a>
          <p class="mt-8 text-sm font-bold uppercase tracking-[0.18em] text-accent">{isRichResource ? 'Rich Resource Page' : post.category}</p>
          <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-primary md:text-5xl">{post.title}</h1>
          <p class="mt-5 max-w-3xl text-xl leading-relaxed text-muted-foreground">{post.description}</p>
          <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm font-semibold text-muted-foreground">
            <span>{formatDate(post.date)}</span>
            <span aria-hidden="true">/</span>
            <span>{post.readTime}</span>
            <span aria-hidden="true">/</span>
            <span>{displayAuthor}</span>
          </div>
        </div>
        {useVideoHero && nativeVideo ? (
          <div class="tw-source-video-card tw-source-video-card--hero rounded-lg border border-border bg-card p-4 shadow-elegant">
            <div id="tw-source-video-frame" class="tw-source-video-frame">
              <div class="tw-source-video-backdrop tw-source-video-backdrop--brand" aria-hidden="true"></div>
              <div class="tw-source-video-shade" aria-hidden="true"></div>
              <video
                id="tw-source-video"
                src={nativeVideo}
                class="tw-source-video-main"
                controls
                preload="metadata"
              />
            </div>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Adapted from a short Talley Wealth educational video. Source moments below jump to the exact parts of the recording.
            </p>
          </div>
        ) : (
          <img decoding="async" src={post.image} alt={post.title} class="aspect-[4/3] w-full rounded-lg object-cover shadow-elegant" loading="eager" />
        )}
      </div>
    </header>

    <div class="section-container grid gap-12 py-16 lg:grid-cols-[minmax(0,720px)_300px] lg:items-start lg:justify-center">
      <div>
        {embedUrl && (
          <div class="mb-10 overflow-hidden rounded-lg border border-border bg-card shadow-elegant">
            <iframe
              src={embedUrl}
              title={`${post.title} video`}
              class="aspect-video w-full"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        )}

        {nativeVideo && !useVideoHero && (
          <div class="tw-source-video-card mb-10 rounded-lg border border-border bg-card p-4 shadow-elegant">
            <div id="tw-source-video-frame" class="tw-source-video-frame">
              <img class="tw-source-video-backdrop" src={post.image} alt="" aria-hidden="true" loading="lazy" />
              <div class="tw-source-video-shade" aria-hidden="true"></div>
              <video
                id="tw-source-video"
                src={nativeVideo}
                poster={post.image}
                class="tw-source-video-main"
                controls
                preload="metadata"
              />
            </div>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Adapted from a short Talley Wealth educational video. Use the source moments below to jump to the parts that support the article.
            </p>
          </div>
        )}

        {hasSourceMoments && (
          <section class="tw-source-moments mb-10 rounded-lg border border-accent/25 bg-card p-6 shadow-elegant" aria-labelledby="source-moments-heading">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">Source moments</p>
            <h2 id="source-moments-heading" class="mt-3 font-serif text-2xl font-bold leading-tight text-primary">Watch the parts that answer the key questions</h2>
            <div class="mt-5 grid gap-4">
              {sourceMoments.map((moment) => (
                <article id={momentId(moment.seconds)} class="tw-source-moment rounded-md border border-border bg-background p-4">
                  <button
                    class="tw-source-moment__jump"
                    type="button"
                    data-seek-seconds={moment.seconds}
