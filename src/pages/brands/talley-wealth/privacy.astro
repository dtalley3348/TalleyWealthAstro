---
import TalleyPage from '../../../components/talley-wealth/TalleyPage.astro';
---

<TalleyPage title="Privacy Policy | Talley Wealth" description="Talley Wealth privacy policy.">
  <section class="bg-muted/35 py-20">
    <div class="section-container">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Privacy</p>
        <h1 class="mt-5 font-serif text-3xl font-bold text-primary md:text-4xl">Privacy Policy</h1>
        <div class="mt-8 space-y-6 text-lg leading-relaxed text-muted-foreground">
          <p>Talley Wealth uses the information you submit through this website to respond to inquiries, process newsletter signups, and manage client or prospective-client communication.</p>
          <p>We do not sell personal information. Information submitted through contact, newsletter, guide, workshop, or Explore Call forms is handled through the platform systems that support this website and the firm's communication process.</p>
          <p>Third-party client portals and Talley Tax links may have their own privacy terms. Those systems are separate from this public website.</p>
          <p>To request an update or deletion of information submitted through the site, contact <a href="mailto:hello@talleywealth.com" class="font-bold text-accent">hello@talleywealth.com</a>.</p>
        </div>
      </div>
    </div>
  </section>
</TalleyPage>
