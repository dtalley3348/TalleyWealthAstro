---
interface Props {
  compact?: boolean;
  animated?: boolean;
  class?: string;
}

const { compact = false, animated = false, class: className = '' } = Astro.props;
const wrapperClass = ['tw-journey-pathway', compact ? 'tw-journey-pathway--compact' : '', animated ? 'tw-journey-pathway--animated' : '', className].filter(Boolean).join(' ');
---

<div class={wrapperClass}>
  <div class="tw-journey-pathway__frame">
    <svg viewBox="0 0 500 200" class="tw-journey-pathway__svg" preserveAspectRatio="xMidYMid meet" role="img" aria-label="A clear path from initial conversation to ongoing advisory">
      <path d="M 60 150 Q 140 140 180 120 Q 220 100 260 90 Q 300 80 340 70 Q 380 60 440 50" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="8,4" class="tw-journey-pathway__dashed" />
      <path d="M 95 130 L 165 105" fill="none" stroke="currentColor" stroke-width="2" class="tw-journey-pathway__connector" />
      <path d="M 205 85 L 275 60" fill="none" stroke="currentColor" stroke-width="2" class="tw-journey-pathway__connector" />
      <path d="M 325 50 L 395 30" fill="none" stroke="currentColor" stroke-width="2" class="tw-journey-pathway__connector" />

      <g class="tw-journey-pathway__waypoint">
        <rect x="40" y="130" width="55" height="55" rx="6" />
        <circle cx="67" cy="145" r="10" />
        <text x="67" y="149" text-anchor="middle" class="tw-journey-pathway__number">1</text>
        <text x="67" y="168" text-anchor="middle" class="tw-journey-pathway__label">
          <tspan x="67" dy="0">Explore</tspan>
          <tspan x="67" dy="10">Call</tspan>
        </text>
      </g>

      <g class="tw-journey-pathway__waypoint">
        <rect x="150" y="90" width="55" height="55" rx="6" />
        <circle cx="177" cy="105" r="10" />
        <text x="177" y="109" text-anchor="middle" class="tw-journey-pathway__number">2</text>
        <text x="177" y="128" text-anchor="middle" class="tw-journey-pathway__label tw-journey-pathway__label--small">
          <tspan x="177" dy="0">Strategy</tspan>
          <tspan x="177" dy="10">Session</tspan>
        </text>
      </g>

      <g class="tw-journey-pathway__keystone">
        <path d="M 260 25 L 310 25 L 305 75 L 265 75 Z" />
        <circle cx="285" cy="40" r="10" />
        <text x="285" y="44" text-anchor="middle" class="tw-journey-pathway__number tw-journey-pathway__number--keystone">3</text>
        <text x="285" y="62" text-anchor="middle" class="tw-journey-pathway__label tw-journey-pathway__label--keystone">
          <tspan x="285" dy="0">Keystone</tspan>
          <tspan x="285" dy="9">Method™</tspan>
        </text>
      </g>

      <g class="tw-journey-pathway__waypoint">
        <rect x="380" y="10" width="60" height="55" rx="6" />
        <circle cx="410" cy="25" r="10" />
        <text x="410" y="29" text-anchor="middle" class="tw-journey-pathway__number">4</text>
        <text x="410" y="46" text-anchor="middle" class="tw-journey-pathway__label tw-journey-pathway__label--small">
          <tspan x="410" dy="0">Ongoing</tspan>
          <tspan x="410" dy="9">Advisory</tspan>
        </text>
      </g>

      <polygon points="125,118 135,122 125,126" class="tw-journey-pathway__arrow" />
      <polygon points="235,78 245,82 235,86" class="tw-journey-pathway__arrow" />
      <polygon points="355,38 365,42 355,46" class="tw-journey-pathway__arrow" />
    </svg>
  </div>

  <div class="tw-journey-pathway__mobile" aria-label="A clear path from initial conversation to ongoing advisory">
    <div class="tw-journey-pathway__mobile-step">
      <span>1</span>
      <p>Explore Call</p>
    </div>
    <div class="tw-journey-pathway__mobile-step">
      <span>2</span>
      <p>Strategy Session</p>
    </div>
    <div class="tw-journey-pathway__mobile-step tw-journey-pathway__mobile-step--keystone">
      <span>3</span>
      <p>Keystone Method™</p>
    </div>
    <div class="tw-journey-pathway__mobile-step">
      <span>4</span>
      <p>Ongoing Advisory</p>
    </div>
  </div>

  {compact ? (
    <p class="tw-journey-pathway__caption tw-journey-pathway__caption--compact">Your journey from first conversation to ongoing partnership</p>
  ) : (
    <p class="tw-journey-pathway__caption">A clear path from initial conversation to <span>lasting partnership</span></p>
  )}
</div>

<style>
  html[data-tenant="talley-wealth"] .tw-journey-pathway {
    color: var(--color-accent);
    width: 100%;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__frame {
    margin-inline: auto;
    max-width: 42rem;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile {
    display: none;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway--compact .tw-journey-pathway__frame {
    max-width: 28rem;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__svg {
    display: block;
    height: auto;
    width: 100%;
    overflow: visible;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__dashed {
    opacity: 0.22;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__connector {
    opacity: 0.52;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__arrow {
    fill: var(--color-accent);
    opacity: 0.66;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__waypoint,
  html[data-tenant="talley-wealth"] .tw-journey-pathway__keystone {
    cursor: default;
    transform-box: fill-box;
    transform-origin: center bottom;
    transition: transform 260ms var(--ease-smooth), filter 260ms var(--ease-smooth);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__waypoint:hover {
    filter: brightness(1.08) drop-shadow(0 8px 14px rgb(0 0 0 / 0.18));
    transform: translateY(-4px);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__keystone:hover {
    filter: brightness(1.12) drop-shadow(0 8px 18px rgb(191 140 77 / 0.4));
    transform: scale(1.06);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__waypoint rect {
    fill: color-mix(in srgb, var(--color-primary-foreground) 90%, transparent);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__waypoint circle {
    fill: var(--color-accent);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__keystone path {
    fill: var(--color-accent);
    filter: drop-shadow(0 14px 22px rgb(191 140 77 / 0.38));
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__keystone circle {
    fill: var(--color-primary);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__number {
    fill: var(--color-accent-foreground);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 800;
    pointer-events: none;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__number--keystone {
    fill: var(--color-primary-foreground);
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__label {
    fill: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 8px;
    font-weight: 800;
    pointer-events: none;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__label--small {
    font-size: 6.5px;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__label--keystone {
    fill: var(--color-accent-foreground);
    font-size: 6px;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__caption {
    margin: 1.5rem auto 0;
    max-width: 38rem;
    text-align: center;
    color: rgb(255 255 255 / 0.52);
    font-size: clamp(1rem, 1.7vw, 1.125rem);
    line-height: 1.7;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__caption span {
    color: var(--color-accent);
    font-weight: 800;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway__caption--compact {
    color: var(--color-muted-foreground);
    font-size: 0.85rem;
  }
  html[data-tenant="talley-wealth"] .tw-journey-pathway--animated .tw-journey-pathway__keystone path {
    animation: tw-pathway-glow 3s ease-in-out infinite;
  }
  @keyframes tw-pathway-glow {
    0%, 100% { filter: drop-shadow(0 0 8px rgb(191 140 77 / 0.42)); }
    50% { filter: drop-shadow(0 0 20px rgb(191 140 77 / 0.72)); }
  }
  @media (prefers-reduced-motion: reduce) {
    html[data-tenant="talley-wealth"] .tw-journey-pathway--animated .tw-journey-pathway__keystone path {
      animation: none;
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__waypoint,
    html[data-tenant="talley-wealth"] .tw-journey-pathway__keystone {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    html[data-tenant="talley-wealth"] .tw-journey-pathway__frame {
      display: none;
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile {
      display: grid;
      gap: 0.75rem;
      margin-inline: auto;
      max-width: 22rem;
      position: relative;
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile::before {
      content: '';
      position: absolute;
      left: 1.375rem;
      top: 1.5rem;
      bottom: 1.5rem;
      width: 2px;
      background: color-mix(in srgb, var(--color-accent) 32%, transparent);
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile-step {
      position: relative;
      display: grid;
      grid-template-columns: 2.75rem 1fr;
      align-items: center;
      gap: 0.875rem;
      border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
      background: color-mix(in srgb, var(--color-card) 92%, transparent);
      border-radius: 0.5rem;
      padding: 0.875rem 1rem;
      box-shadow: var(--shadow-elegant);
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile-step span {
      display: grid;
      place-items: center;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 9999px;
      background: var(--color-accent);
      color: var(--color-accent-foreground);
      font-weight: 800;
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile-step p {
      color: var(--color-primary);
      font-weight: 800;
      line-height: 1.2;
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile-step--keystone {
      background: var(--color-primary);
      border-color: var(--color-accent);
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__mobile-step--keystone p {
      color: var(--color-primary-foreground);
    }
    html[data-tenant="talley-wealth"] .tw-journey-pathway__caption {
      margin-top: 1rem;
    }
  }
</style>
